<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
<meta name="description" content="{{ description or site.description }}">
<link rel="stylesheet" href="/css/style.css">
<script>
  window.SITE = {
    imageBase: {{ site.imageBase | dump | safe }},
    cryptopunksDetailsBase: {{ site.cryptopunksDetailsBase | dump | safe }},
    cryptopunksAccountBase: {{ site.cryptopunksAccountBase | dump | safe }},
    etherscanAddressBase: {{ site.etherscanAddressBase | dump | safe }},
    burnedPunksUrl: {{ site.burnedPunksUrl | dump | safe }},
  };
</script>
</head>
<body class="{{ bodyClass or '' }}">
<header class="site-header">
  <a class="site-header__logo" href="/" aria-label="{{ site.title }} home">
    <img src="/images/logos/lostpunks.gif" alt="{{ site.title }}">
  </a>
  <nav class="site-nav" aria-label="Primary">
    <ul>
      <li><a href="/lookup/"{% if page.url == "/lookup/" %} aria-current="page"{% endif %}>Look up</a></li>
      <li><a href="/search/"{% if page.url == "/search/" %} aria-current="page"{% endif %}>Search</a></li>
      <li><a href="/about/"{% if page.url == "/about/" %} aria-current="page"{% endif %}>About</a></li>
    </ul>
  </nav>
</header>

<main>
{{ content | safe }}
</main>

<footer class="site-footer">
  <p>
    A <a href="https://punkspunkspunks.com">PunksPunksPunks</a> project by <a href="http://seanbonner.com/">Sean Bonner</a>, published under a <a href="https://creativecommons.org/licenses/by/4.0/">CC-BY 4.0 License</a>.
  </p>
</footer>
</body>
</html>
