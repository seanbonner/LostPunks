---
layout: layouts/base.njk
permalink: /
bodyClass: home
---

<section class="home-hero">
  <div class="home-hero__header">
    <a class="home-hero__logo" href="/" aria-label="Lost Punks">
      <img src="/images/logos/lostpunks.gif" alt="Lost Punks">
    </a>

    <p class="home-hero__headline">
      Forgotten wallets. Misplaced seedphrases. Hundreds of CryptoPunks might be lost forever&hellip; but which ones?
    </p>

    <p class="entry-links">
      <a href="/lookup/">Look up a punk →</a>
      <a href="/search/">Search by threshold →</a>
    </p>
  </div>

  <div class="mosaic">
    <div class="mosaic__grid">
      {%- set tileTotal = punks.topDormant.v2 | length -%}
      {% for id in punks.topDormant.v2 %}
        {%- set fade = 0.02 + (loop.index0 / (tileTotal - 1)) * 0.98 -%}
        <a class="mosaic__tile" href="/lookup/?punk={{ id }}" aria-label="Punk {{ id }}" style="--tile-fade: {{ fade }}">
          <img class="mosaic__tile-img" src="{{ site.imageBase }}{{ id }}/image?transparent=true&bg=ffffff" alt="" loading="lazy" width="96" height="96">
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  // Crop the mosaic to exactly 9 rows by detecting row breaks via offsetTop.
  (function () {
    const grid = document.querySelector(".mosaic__grid");
    if (!grid) return;
    const tiles = Array.from(grid.children);
    const ROWS = 9;
    function trim() {
      tiles.forEach((t) => { t.hidden = false; });
      let rowCount = 1;
      let cutoff = tiles.length;
      let prevTop = tiles[0].offsetTop;
      for (let i = 1; i < tiles.length; i++) {
        const top = tiles[i].offsetTop;
        if (top !== prevTop) {
          rowCount++;
          prevTop = top;
          if (rowCount > ROWS) { cutoff = i; break; }
        }
      }
      for (let i = cutoff; i < tiles.length; i++) tiles[i].hidden = true;
    }
    trim();
    window.addEventListener("resize", trim);
  })();
</script>
