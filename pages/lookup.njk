  <form id="lookup-form" autocomplete="off">
    <label for="lookup-id">Punk number</label>
    <input type="number" id="lookup-id" min="0" max="9999" required>
    <button type="submit">Go</button>
  </form>

  <div id="lookup-result" hidden></div>
</div>

<script src="/js/lookup.js" type="module"></script>
